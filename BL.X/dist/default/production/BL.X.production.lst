 22867                           ;Config register CONFIG1 @ 0x300000
 22868                           ;	External Oscillator Selection
 22869                           ;	FEXTOSC = ECH, EC (external clock) above 8 MHz
 22870                           ;	Reset Oscillator Selection
 22871                           ;	RSTOSC = HFINTOSC_64MHZ, HFINTOSC with HFFRQ = 64 MHz and CDIV = 1:1
 22872   300000                     	org	3145728
 22873   300000  8F                 	db	143
 22874                           
 22875                           ;Config register CONFIG2 @ 0x300001
 22876                           ;	Clock out Enable bit
 22877                           ;	CLKOUTEN = OFF, CLKOUT function is disabled
 22878                           ;	PRLOCKED One-Way Set Enable bit
 22879                           ;	PR1WAY = ON, PRLOCKED bit can be cleared and set only once
 22880                           ;	Clock Switch Enable bit
 22881                           ;	CSWEN = ON, Writing to NOSC and NDIV is allowed
 22882                           ;	Fail-Safe Clock Monitor Enable bit
 22883                           ;	FCMEN = ON, Fail-Safe Clock Monitor enabled
 22884   300001                     	org	3145729
 22885   300001  FF                 	db	255
 22886                           
 22887                           ;Config register CONFIG3 @ 0x300002
 22888                           ;	MCLR Enable bit
 22889                           ;	MCLRE = EXTMCLR, If LVP = 0, MCLR pin is MCLR; If LVP = 1, RE3 pin function is MCLR
 22890                           ;	Power-up timer selection bits
 22891                           ;	PWRTS = PWRT_OFF, PWRT is disabled
 22892                           ;	Multi-vector enable bit
 22893                           ;	MVECEN = ON, Multi-vector enabled, Vector table used for interrupts
 22894                           ;	IVTLOCK bit One-way set enable bit
 22895                           ;	IVT1WAY = OFF, IVTLOCKED bit can be cleared and set repeatedly
 22896                           ;	Low Power BOR Enable bit
 22897                           ;	LPBOREN = OFF, Low-Power BOR disabled
 22898                           ;	Brown-out Reset Enable bits
 22899                           ;	BOREN = SBORDIS, Brown-out Reset enabled , SBOREN bit is ignored
 22900   300002                     	org	3145730
 22901   300002  EF                 	db	239
 22902                           
 22903                           ;Config register CONFIG4 @ 0x300003
 22904                           ;	Brown-out Reset Voltage Selection bits
 22905                           ;	BORV = VBOR_1P9, Brown-out Reset Voltage (VBOR) set to 1.9V
 22906                           ;	ZCD Disable bit
 22907                           ;	ZCD = OFF, ZCD module is disabled. ZCD can be enabled by setting the ZCDSEN bit of ZCD
      +                          CON
 22908                           ;	PPSLOCK bit One-Way Set Enable bit
 22909                           ;	PPS1WAY = ON, PPSLOCKED bit can be cleared and set only once; PPS registers remain loc
      +                          ked after one clear/set cycle
 22910                           ;	Stack Full/Underflow Reset Enable bit
 22911                           ;	STVREN = ON, Stack full/underflow will cause Reset
 22912                           ;	Low Voltage Programming Enable bit
 22913                           ;	LVP = ON, Low voltage programming enabled. MCLR/VPP pin function is MCLR. MCLRE config
      +                          uration bit is ignored
 22914                           ;	Extended Instruction Set Enable bit
 22915                           ;	XINST = OFF, Extended Instruction Set and Indexed Addressing Mode disabled
 22916   300003                     	org	3145731
 22917   300003  FF                 	db	255
 22918                           
 22919                           ;Config register CONFIG5 @ 0x300004
 22920                           ;	WDT Period selection bits
 22921                           ;	WDTCPS = WDTCPS_31, Divider ratio 1:65536; software control of WDTPS
 22922                           ;	WDT operating mode
 22923                           ;	WDTE = OFF, WDT Disabled; SWDTEN is ignored
 22924   300004                     	org	3145732
 22925   300004  9F                 	db	159
 22926                           
 22927                           ;Config register CONFIG6 @ 0x300005
 22928                           ;	WDT Window Select bits
 22929                           ;	WDTCWS = WDTCWS_7, window always open (100%); software control; keyed access not requi
      +                          red
 22930                           ;	WDT input clock selector
 22931                           ;	WDTCCS = SC, Software Control
 22932   300005                     	org	3145733
 22933   300005  FF                 	db	255
 22934                           
 22935                           ;Config register CONFIG7 @ 0x300006
 22936                           ;	Boot Block Size selection bits
 22937                           ;	BBSIZE = BBSIZE_512, Boot Block size is 512 words
 22938                           ;	Boot Block enable bit
 22939                           ;	BBEN = OFF, Boot block disabled
 22940                           ;	Storage Area Flash enable bit
 22941                           ;	SAFEN = OFF, SAF disabled
 22942                           ;	Background Debugger
 22943                           ;	DEBUG = 0x1, unprogrammed default
 22944   300006                     	org	3145734
 22945   300006  FF                 	db	255
 22946                           
 22947                           ;Config register CONFIG8 @ 0x300007
 22948                           ;	Boot Block Write Protection bit
 22949                           ;	WRTB = OFF, Boot Block not Write protected
 22950                           ;	Configuration Register Write Protection bit
 22951                           ;	WRTC = OFF, Configuration registers not Write protected
 22952                           ;	Data EEPROM Write Protection bit
 22953                           ;	WRTD = OFF, Data EEPROM not Write protected
 22954                           ;	SAF Write protection bit
 22955                           ;	WRTSAF = OFF, SAF not Write Protected
 22956                           ;	Application Block write protection bit
 22957                           ;	WRTAPP = OFF, Application Block not write protected
 22958   300007                     	org	3145735
