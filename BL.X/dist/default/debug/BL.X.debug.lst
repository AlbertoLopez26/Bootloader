 22296                           ;Config register CONFIG1 @ 0x300000
 22297                           ;	External Oscillator Selection
 22298                           ;	FEXTOSC = ECH, EC (external clock) above 8 MHz
 22299                           ;	Reset Oscillator Selection
 22300                           ;	RSTOSC = HFINTOSC_64MHZ, HFINTOSC with HFFRQ = 64 MHz and CDIV = 1:1
 22301   300000                     	org	3145728
 22302   300000  8F                 	db	143
 22303                           
 22304                           ;Config register CONFIG2 @ 0x300001
 22305                           ;	Clock out Enable bit
 22306                           ;	CLKOUTEN = OFF, CLKOUT function is disabled
 22307                           ;	PRLOCKED One-Way Set Enable bit
 22308                           ;	PR1WAY = ON, PRLOCKED bit can be cleared and set only once
 22309                           ;	Clock Switch Enable bit
 22310                           ;	CSWEN = ON, Writing to NOSC and NDIV is allowed
 22311                           ;	Fail-Safe Clock Monitor Enable bit
 22312                           ;	FCMEN = ON, Fail-Safe Clock Monitor enabled
 22313   300001                     	org	3145729
 22314   300001  FF                 	db	255
 22315                           
 22316                           ;Config register CONFIG3 @ 0x300002
 22317                           ;	MCLR Enable bit
 22318                           ;	MCLRE = EXTMCLR, If LVP = 0, MCLR pin is MCLR; If LVP = 1, RE3 pin function is MCLR
 22319                           ;	Power-up timer selection bits
 22320                           ;	PWRTS = PWRT_OFF, PWRT is disabled
 22321                           ;	Multi-vector enable bit
 22322                           ;	MVECEN = ON, Multi-vector enabled, Vector table used for interrupts
 22323                           ;	IVTLOCK bit One-way set enable bit
 22324                           ;	IVT1WAY = OFF, IVTLOCKED bit can be cleared and set repeatedly
 22325                           ;	Low Power BOR Enable bit
 22326                           ;	LPBOREN = OFF, Low-Power BOR disabled
 22327                           ;	Brown-out Reset Enable bits
 22328                           ;	BOREN = SBORDIS, Brown-out Reset enabled , SBOREN bit is ignored
 22329   300002                     	org	3145730
 22330   300002  EF                 	db	239
 22331                           
 22332                           ;Config register CONFIG4 @ 0x300003
 22333                           ;	Brown-out Reset Voltage Selection bits
 22334                           ;	BORV = VBOR_1P9, Brown-out Reset Voltage (VBOR) set to 1.9V
 22335                           ;	ZCD Disable bit
 22336                           ;	ZCD = OFF, ZCD module is disabled. ZCD can be enabled by setting the ZCDSEN bit of ZCD
      +                          CON
 22337                           ;	PPSLOCK bit One-Way Set Enable bit
 22338                           ;	PPS1WAY = ON, PPSLOCKED bit can be cleared and set only once; PPS registers remain loc
      +                          ked after one clear/set cycle
 22339                           ;	Stack Full/Underflow Reset Enable bit
 22340                           ;	STVREN = ON, Stack full/underflow will cause Reset
 22341                           ;	Low Voltage Programming Enable bit
 22342                           ;	LVP = ON, Low voltage programming enabled. MCLR/VPP pin function is MCLR. MCLRE config
      +                          uration bit is ignored
 22343                           ;	Extended Instruction Set Enable bit
 22344                           ;	XINST = OFF, Extended Instruction Set and Indexed Addressing Mode disabled
 22345   300003                     	org	3145731
 22346   300003  FF                 	db	255
 22347                           
 22348                           ;Config register CONFIG5 @ 0x300004
 22349                           ;	WDT Period selection bits
 22350                           ;	WDTCPS = WDTCPS_31, Divider ratio 1:65536; software control of WDTPS
 22351                           ;	WDT operating mode
 22352                           ;	WDTE = OFF, WDT Disabled; SWDTEN is ignored
 22353   300004                     	org	3145732
 22354   300004  9F                 	db	159
 22355                           
 22356                           ;Config register CONFIG6 @ 0x300005
 22357                           ;	WDT Window Select bits
 22358                           ;	WDTCWS = WDTCWS_7, window always open (100%); software control; keyed access not requi
      +                          red
 22359                           ;	WDT input clock selector
 22360                           ;	WDTCCS = SC, Software Control
 22361   300005                     	org	3145733
 22362   300005  FF                 	db	255
 22363                           
 22364                           ;Config register CONFIG7 @ 0x300006
 22365                           ;	Boot Block Size selection bits
 22366                           ;	BBSIZE = BBSIZE_512, Boot Block size is 512 words
 22367                           ;	Boot Block enable bit
 22368                           ;	BBEN = OFF, Boot block disabled
 22369                           ;	Storage Area Flash enable bit
 22370                           ;	SAFEN = OFF, SAF disabled
 22371                           ;	Background Debugger
 22372                           ;	DEBUG = 0x1, unprogrammed default
 22373   300006                     	org	3145734
 22374   300006  FF                 	db	255
 22375                           
 22376                           ;Config register CONFIG8 @ 0x300007
 22377                           ;	Boot Block Write Protection bit
 22378                           ;	WRTB = OFF, Boot Block not Write protected
 22379                           ;	Configuration Register Write Protection bit
 22380                           ;	WRTC = OFF, Configuration registers not Write protected
