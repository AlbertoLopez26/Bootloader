 22801                           
 22802                           ;Config register CONFIG1 @ 0x300000
 22803                           ;	External Oscillator Selection
 22804                           ;	FEXTOSC = ECH, EC (external clock) above 8 MHz
 22805                           ;	Reset Oscillator Selection
 22806                           ;	RSTOSC = HFINTOSC_64MHZ, HFINTOSC with HFFRQ = 64 MHz and CDIV = 1:1
 22807   300000                     	org	3145728
 22808   300000  8F                 	db	143
 22809                           
 22810                           ;Config register CONFIG2 @ 0x300001
 22811                           ;	Clock out Enable bit
 22812                           ;	CLKOUTEN = OFF, CLKOUT function is disabled
 22813                           ;	PRLOCKED One-Way Set Enable bit
 22814                           ;	PR1WAY = ON, PRLOCKED bit can be cleared and set only once
 22815                           ;	Clock Switch Enable bit
 22816                           ;	CSWEN = ON, Writing to NOSC and NDIV is allowed
 22817                           ;	Fail-Safe Clock Monitor Enable bit
 22818                           ;	FCMEN = ON, Fail-Safe Clock Monitor enabled
 22819   300001                     	org	3145729
 22820   300001  FF                 	db	255
 22821                           
 22822                           ;Config register CONFIG3 @ 0x300002
 22823                           ;	MCLR Enable bit
 22824                           ;	MCLRE = EXTMCLR, If LVP = 0, MCLR pin is MCLR; If LVP = 1, RE3 pin function is MCLR
 22825                           ;	Power-up timer selection bits
 22826                           ;	PWRTS = PWRT_OFF, PWRT is disabled
 22827                           ;	Multi-vector enable bit
 22828                           ;	MVECEN = ON, Multi-vector enabled, Vector table used for interrupts
 22829                           ;	IVTLOCK bit One-way set enable bit
 22830                           ;	IVT1WAY = OFF, IVTLOCKED bit can be cleared and set repeatedly
 22831                           ;	Low Power BOR Enable bit
 22832                           ;	LPBOREN = OFF, Low-Power BOR disabled
 22833                           ;	Brown-out Reset Enable bits
 22834                           ;	BOREN = SBORDIS, Brown-out Reset enabled , SBOREN bit is ignored
 22835   300002                     	org	3145730
 22836   300002  EF                 	db	239
 22837                           
 22838                           ;Config register CONFIG4 @ 0x300003
 22839                           ;	Brown-out Reset Voltage Selection bits
 22840                           ;	BORV = VBOR_1P9, Brown-out Reset Voltage (VBOR) set to 1.9V
 22841                           ;	ZCD Disable bit
 22842                           ;	ZCD = OFF, ZCD module is disabled. ZCD can be enabled by setting the ZCDSEN bit of ZCD
      +                          CON
 22843                           ;	PPSLOCK bit One-Way Set Enable bit
 22844                           ;	PPS1WAY = ON, PPSLOCKED bit can be cleared and set only once; PPS registers remain loc
      +                          ked after one clear/set cycle
 22845                           ;	Stack Full/Underflow Reset Enable bit
 22846                           ;	STVREN = ON, Stack full/underflow will cause Reset
 22847                           ;	Low Voltage Programming Enable bit
 22848                           ;	LVP = ON, Low voltage programming enabled. MCLR/VPP pin function is MCLR. MCLRE config
      +                          uration bit is ignored
 22849                           ;	Extended Instruction Set Enable bit
 22850                           ;	XINST = OFF, Extended Instruction Set and Indexed Addressing Mode disabled
 22851   300003                     	org	3145731
 22852   300003  FF                 	db	255
 22853                           
 22854                           ;Config register CONFIG5 @ 0x300004
 22855                           ;	WDT Period selection bits
 22856                           ;	WDTCPS = WDTCPS_31, Divider ratio 1:65536; software control of WDTPS
 22857                           ;	WDT operating mode
 22858                           ;	WDTE = OFF, WDT Disabled; SWDTEN is ignored
 22859   300004                     	org	3145732
 22860   300004  9F                 	db	159
 22861                           
 22862                           ;Config register CONFIG6 @ 0x300005
 22863                           ;	WDT Window Select bits
 22864                           ;	WDTCWS = WDTCWS_7, window always open (100%); software control; keyed access not requi
      +                          red
 22865                           ;	WDT input clock selector
 22866                           ;	WDTCCS = SC, Software Control
 22867   300005                     	org	3145733
 22868   300005  FF                 	db	255
 22869                           
 22870                           ;Config register CONFIG7 @ 0x300006
 22871                           ;	Boot Block Size selection bits
